digraph AcquisitionArchitecture {
  graph [rankdir=LR, bgcolor="white", pad=0.25, nodesep=0.45, ranksep=0.7];
  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10,
        color="#64748b", fillcolor="#f8fafc"];
  edge [color="#64748b", fontname="Arial", fontsize=9];

  subgraph cluster_sources {
    label="Protocol-specific sources";
    color="#cbd5e1";
    ads [label="SerialADS1299Source\nparser + device counter", fillcolor="#e0f2fe"];
    w2 [label="BLEW2Source\nparser + configured rate", fillcolor="#e0f2fe"];
    myo [label="MyoSource\npymyo + EMG/IMU callbacks", fillcolor="#e0f2fe"];
  }

  schema [label="StreamSpec + FieldSpec\nrate, time source, columns, plot hints",
          fillcolor="#ede9fe"];
  block [label="StreamBlock\none independently sampled stream", fillcolor="#ede9fe"];
  controller [label="AcquisitionController\nlifecycle + queues + session metadata",
              fillcolor="#dcfce7"];
  store [label="CaptureStore\nfull rows + bounded series windows", fillcolor="#dcfce7"];
  plot [label="Plot window\ngeneric series provider", fillcolor="#fef3c7"];
  future [label="Future 3D / analysis view\nquery only required IMU series", fillcolor="#fef3c7"];
  csv [label="Schema-driven CSV writer\none raw file per populated stream", fillcolor="#fee2e2"];
  meta [label="Capture metadata JSON\nshared session + schemas + timing", fillcolor="#fee2e2"];

  ads -> schema;
  w2 -> schema;
  myo -> schema;
  ads -> block;
  w2 -> block;
  myo -> block;
  schema -> controller [label="configure"];
  block -> controller [label="queue"];
  controller -> store [label="append / resume cursors"];
  store -> plot [label="SeriesWindow"];
  store -> future [label="SeriesWindow"];
  store -> csv [label="StreamSnapshot"];
  controller -> meta [label="session/device metadata"];
  csv -> meta [label="files + row counts"];
}
